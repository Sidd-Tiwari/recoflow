#!/bin/sh
# Maven Wrapper Script
set -e

# Find the project base dir
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(pwd)}"

# Resolve .mvn directory
WRAPPERDIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
WRAPPER_JAR="$WRAPPERDIR/maven-wrapper.jar"
WRAPPER_PROPERTIES="$WRAPPERDIR/maven-wrapper.properties"

# Read distribution URL
DISTRIBUTION_URL=$(grep "distributionUrl" "$WRAPPER_PROPERTIES" | cut -d= -f2)

# Check if mvn is available
if command -v mvn >/dev/null 2>&1; then
    exec mvn "$@"
fi

# Download maven if needed
MAVEN_HOME="${MAVEN_HOME:-$HOME/.m2/wrapper}"
MAVEN_BIN="$MAVEN_HOME/bin/mvn"

if [ ! -f "$MAVEN_BIN" ]; then
    echo "Downloading Maven..."
    mkdir -p "$MAVEN_HOME"
    curl -sL "$DISTRIBUTION_URL" -o /tmp/maven.zip
    unzip -q /tmp/maven.zip -d /tmp/
    MAVEN_DIR=$(find /tmp -maxdepth 1 -name "apache-maven-*" -type d | head -1)
    mv "$MAVEN_DIR"/* "$MAVEN_HOME/"
fi

exec "$MAVEN_BIN" "$@"
